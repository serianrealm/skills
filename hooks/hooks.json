{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit|Read|Grep|Glob|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/bin/guard.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/bin/guard.py\""
          }
        ]
      }
    ]
  }
}
